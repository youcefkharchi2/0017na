<!DOCTYPE html>
<html>
<head>
  <title>Dashboard</title>
</head>
<body>

<h1>🔥 Dashboard</h1>

<p><b>User:</b> <%= user.username %></p>

<h3>Servers:</h3>
<ul>
  <% if (user.guilds) { %>
    <% user.guilds.forEach(guild => { %>
      <li><%= guild.name %></li>
    <% }) %>
  <% } %>
</ul>

<br>
<a href="/logout"><button>Logout</button></a>

</body>
</html>
